+package com.android.server.wm;
+
+import android.animation.Animator;
+import android.animation.AnimatorListenerAdapter;
+import android.animation.ValueAnimator;
+import android.content.Context;
+import android.content.pm.ActivityInfo;
+import android.content.pm.ApplicationInfo;
+import android.content.res.Resources;
+import android.graphics.Canvas;
+import android.graphics.Color;
+import android.graphics.Paint;
+import android.graphics.PixelFormat;
+import android.graphics.drawable.Drawable;
+import android.util.Log;
+import android.view.Gravity;
+import android.view.View;
+import android.view.WindowInsets;
+import android.view.WindowManager;
+import android.view.animation.Interpolator;
+import android.view.animation.PathInterpolator;
+
+public class FreeformResizeAnimation {
+
+    private static final String TAG = "FreeformResizeAnimation";
+    private ValueAnimator mAnimator;
+
+    public static final Interpolator LINEAR_OUT_SLOW_IN = new PathInterpolator(0f, 0.5f, 0.8f, 1f);
+
+    private ActivityTaskManagerService mService;
+    private WindowManager mWindowManager;
+    private Task mTask;
+    private RoundRectWindow roundRectWindow;
+    private int mLeftStart,mLeftEnd, mmRight;
+    private Listener mListener;
+    /*
+    * 动画时间
+    * */
+    private int duration = 500;
+    /*
+    * 延时
+    * */
+    private int delay = 200;
+    /*
+    * 圆角大小
+    * */
+    private int roundRadius = 10;
+
+    /*
+    * icon 大小。半径
+    * */
+    private int mIconBounds = 25;
+    private boolean mBoundsScale;
+
+    private FreeformResizeAnimation() {}
+    private static class Holder {
+        private static final FreeformResizeAnimation INSTANCE = new FreeformResizeAnimation();
+    }
+    public static FreeformResizeAnimation getInstance() {
+        return Holder.INSTANCE;
+    }
+
+    public FreeformResizeAnimation addContext(ActivityTaskManagerService mService) {
+        this.mService = mService;
+        mWindowManager = (WindowManager) mService.mContext.getSystemService(Context.WINDOW_SERVICE);
+        return this;
+    }
+
+    /**
+     * 启动自由窗口调整大小的动画效果
+     *
+     * @param task 要执行动画的任务对象，不能为 null
+     * @param leftStart 左侧起始位置坐标
+     * @param leftEnd 左侧结束位置坐标
+     * @param right 右侧位置坐标
+     * @param boundsScale true  窗口变大，此时可以监听 onResizeScaleUp，然后去做resize
+     *                    false  缩小窗口，此时监听onResizeScaleDown，再去resize
+     */
+    public synchronized void startAnimation(Task task,int leftStart, int leftEnd,int right,boolean boundsScale,Listener mListener) {
+        if (leftStart == leftEnd) {
+            return;
+        }
+
+        if (mAnimator != null) {
+            mAnimator.cancel();
+            Log.e(TAG, "Animation: cancelled ");
+            return;
+        }
+
+        mLeftStart = leftStart;
+        mLeftEnd = leftEnd;
+        mmRight = right;
+        mTask = task;
+        mBoundsScale = boundsScale;
+        if (mTask == null){
+            return;
+        }
+        roundRectWindow = new RoundRectWindow(mService.mContext);
+        addWindow();
+
+        mAnimator = ValueAnimator
+                .ofInt(mLeftStart, mLeftEnd)
+                .setDuration(duration);
+        mAnimator.setInterpolator(LINEAR_OUT_SLOW_IN);
+
+        mAnimator.addUpdateListener(
+                animation -> updateBounds(
+                        (int) animation.getAnimatedValue())
+
+        );
+        mAnimator.addListener(new AnimatorListenerAdapter() {
+            @Override
+            public void onAnimationStart(Animator animation) {
+                if (mListener != null) mListener.onResizeScaleDown();
+            }
+
+            @Override
+            public void onAnimationEnd(Animator animation) {
+                if (mListener != null) mListener.onResizeScaleUp();
+                mService.mH.postDelayed(()->{
+                    removeWindow();
+                    mAnimator = null;
+                },delay);
+            }
+
+            @Override
+            public void onAnimationCancel(Animator animation) {
+                removeWindow();
+                mAnimator = null;
+            }
+        });
+
+        if (boundsScale){
+            mAnimator.setStartDelay(delay);
+        }
+        if (mAnimator != null)mAnimator.start();
+    }
+
+    private void updateBounds(int position) {
+        if (roundRectWindow != null){
+            roundRectWindow.setOffset(position);
+        }
+    }
+
+    /**
+     * 加载应用信息图标
+     *
+     * @return Drawable 应用图标对象，如果加载失败则返回 null
+     */
+    private Drawable loadAppInfoIcon() {
+        try {
+            ActivityInfo info = mTask.topRunningActivity().info;
+            ApplicationInfo appInfo = info.applicationInfo;
+            Resources resources = mService.mContext.getPackageManager()
+                    .getResourcesForApplication(appInfo);
+            return resources.getDrawableForDensity(appInfo.icon, resources.getConfiguration().densityDpi);
+        } catch (Exception exc) {
+            Log.w(TAG, "Failed to load app icon", exc);
+        }
+        return null;
+    }
+
+    /*
+     * Window
+     * */
+    private void addWindow() {
+        final WindowManager.LayoutParams mWindowParams = new WindowManager.LayoutParams();
+        mWindowParams.type = WindowManager.LayoutParams.TYPE_PHONE;
+        mWindowParams.format = PixelFormat.TRANSLUCENT;
+        mWindowParams.flags =
+                WindowManager.LayoutParams.FLAG_NOT_TOUCH_MODAL
+                        | WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE
+                        | WindowManager.LayoutParams.FLAG_WATCH_OUTSIDE_TOUCH
+                        | WindowManager.LayoutParams.FLAG_SPLIT_TOUCH;
+        mWindowParams.setTitle("RoundWindow");
+        mWindowParams.width = WindowManager.LayoutParams.MATCH_PARENT;
+        mWindowParams.height = WindowManager.LayoutParams.MATCH_PARENT;
+        /*mWindowParams.height =mTask.getBounds().height();*/
+        mWindowParams.gravity = Gravity.LEFT|Gravity.TOP;
+        mWindowParams.setFitInsetsTypes(WindowInsets.Type.navigationBars());
+//        mWindowParams.setFitInsetsTypes(0);
+        mWindowParams.layoutInDisplayCutoutMode =
+                WindowManager.LayoutParams.LAYOUT_IN_DISPLAY_CUTOUT_MODE_ALWAYS;
+        mWindowManager.addView(roundRectWindow, mWindowParams);
+    }
+
+    private void removeWindow() {
+        if (roundRectWindow == null)return;
+        mWindowManager.removeViewImmediate(roundRectWindow);
+        roundRectWindow = null;
+    }
+
+    /*
+    * View
+    * */
+   private class RoundRectWindow extends View {
+        private final Paint mPaint;
+        private Drawable mIcon;
+        private int offset = 0;
+        private int mmLeft;
+
+        public RoundRectWindow(Context context) {
+            super(context);
+            mPaint = new Paint(Paint.ANTI_ALIAS_FLAG);
+            mPaint.setDither(true);
+            mPaint.setStrokeWidth(1);
+            mPaint.setColor(Color.BLACK);
+            mIcon = loadAppInfoIcon();
+            mmLeft = mLeftStart;
+        }
+
+        public void setOffset(int left){
+            offset = left;
+            if (mBoundsScale) offset = left - mmLeft;
+            invalidate();
+        }
+
+        @Override
+        protected void onDraw(Canvas canvas) {
+            super.onDraw(canvas);
+
+            canvas.drawRoundRect(mmLeft+offset, 0, mmRight, getHeight(), roundRadius, roundRadius, mPaint);
+
+            if (mIcon != null){
+                canvas.save();
+                if (mBoundsScale){
+                    mIcon.setBounds( (mmRight - (offset + mmLeft))/2 +(offset + mmLeft)-mIconBounds,
+                            getHeight()/2 -mIconBounds,  (mmRight - (offset + mmLeft))/2 +(offset + mmLeft)+ mIconBounds,
+                            getHeight()/2 +mIconBounds);
+                }else {
+                    mIcon.setBounds((mmRight - mmLeft -offset)/2 -mIconBounds + offset,
+                            getHeight()/2 -mIconBounds, (mmRight - mmLeft -offset)/2 +mIconBounds + offset,
+                            getHeight()/2 +mIconBounds);
+                }
+                mIcon.draw(canvas);
+                canvas.restore();
+            }
+        }
+    }
+
+    /*
+    * 回调
+    * */
+    static class Listener{
+        void onResizeScaleDown(){}
+       void onResizeScaleUp(){}
+    }
+}
