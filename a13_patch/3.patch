diff --git a/packages/ExampleApk/Android.bp b/packages/ExampleApk/Android.bp
new file mode 100644
index 000000000000..2f96bbace3f0
--- /dev/null
+++ b/packages/ExampleApk/Android.bp
@@ -0,0 +1,49 @@
+android_app {
+
+    name: "ExampleApk",
+
+    platform_apis: true,
+    system_ext_specific: true,
+    certificate: "platform",
+    privileged: true,
+
+    kotlincflags: ["-Xjvm-default=enable"],
+    optimize: {
+        proguard_flags_files: ["proguard.flags"],
+    },
+
+    libs: [
+       "kotlin-annotations",
+       "app-compat-annotations",
+    ],
+
+    static_libs: [
+        "kotlin-stdlib",
+        "androidx.appcompat_appcompat",
+        "androidx.legacy_legacy-support-core-ui",
+        "androidx.legacy_legacy-support-v13",
+        "androidx.legacy_legacy-support-v4",
+        "androidx.recyclerview_recyclerview",
+        "androidx.recyclerview_recyclerview-selection",
+        "androidx.transition_transition",
+        "apache-commons-compress",
+        "com.google.android.material_material",
+        "guava",
+        "modules-utils-build_system",
+    ],
+
+   manifest: "AndroidManifest.xml",
+
+   srcs: [
+       "src/**/*.java",
+   ],
+
+   resource_dirs: [
+        "res",
+   ],
+
+   required: [
+       "privapp_whitelist_com.android.exampleapk",
+   ],
+}
+
